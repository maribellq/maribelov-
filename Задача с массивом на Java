public class AveragePositive {
    public static void main(String[] args) {
        int[] arr = {5, -3, 7, 0, -1, 8, 2};
        int sum = 0;
        int count = 0;
        for (int num : arr) {
            if (num > 0) {
                sum += num;
                count++;
            }
        }
        if (count > 0) {
            double average = (double) sum / count;
            System.out.println("Среднее арифметическое положительных элементов: " + average);
        } else {
            System.out.println("В массиве нет положительных элементов.");
        }
    }
}
