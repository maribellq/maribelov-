# Задача: Дан массив из N целых чисел. Найти количество положительных элементов и вывести их сумму. C++
int main() {
    const int N = 8;
    int arr[N] = {3, -1, 7, 0, -5, 9, 2, -4};
    int count_positive = 0;
    int sum_positive = 0;
    for (int i = 0; i < N; ++i) {
        if (arr[i] > 0) {
            count_positive++;
            sum_positive += arr[i];
        }
    }
    std::cout << "Количество положительных элементов: " << count_positive << std::endl;
    std::cout << "Сумма положительных элементов: " << sum_positive << std::endl;
    return 0;
}
#Используется обычный статический массив arr фиксированного размера N. В цикле перебираются все элементы массива. Если элемент положительный (> 0), увеличиваем счётчик и прибавляем к сумме. В конце выводим количество и сумму положительных чисел.
